# ── Wallet ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=your_wallet_private_key_base58_here

# ── RPC ─────────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_key
# Free RPC (rate limited): https://api.mainnet-beta.solana.com

# ── AI ──────────────────────────────────────────────────────────────────────
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_groq_api_key_here
# Anthropic (opsional, untuk dual AI):
ANTHROPIC_API_KEY=

# ── Telegram Alerts (opsional) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LP Agent (opsional, untuk blockchain position sync) ───────────────────────
LP_AGENT_API_KEY=

# ── Strategy ─────────────────────────────────────────────────────────────────
SOL_PER_POSITION=0.1
MAX_POSITIONS=1
MIN_FEE_APR=50
DEFAULT_BIN_RANGE=34
MAX_LOSS_PERCENT=8
CHECK_INTERVAL_SECONDS=60
