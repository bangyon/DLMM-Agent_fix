# ===== WALLET =====
PRIVATE_KEY=your_base58_private_key_here

# ===== RPC (pilih salah satu, Helius direkomendasikan) =====
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# RPC_URL=https://api.mainnet-beta.solana.com

# ===== AI PROVIDER (pilih salah satu) =====
# Option 1: OpenRouter (akses banyak model)
OPENROUTER_API_KEY=sk-or-...
AI_MODEL=anthropic/claude-3-haiku

# Option 2: Groq (gratis, cepat)
# GROQ_API_KEY=gsk_...
# AI_MODEL=llama3-70b-8192

# Option 3: Anthropic langsung
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-3-haiku-20240307

AI_PROVIDER=openrouter
# AI_PROVIDER=groq
# AI_PROVIDER=anthropic

# ===== AGENT CONFIG =====
# Berapa SOL yang boleh dipakai per posisi (default 0.1)
SOL_PER_POSITION=0.1
# Maksimum posisi aktif bersamaan
MAX_POSITIONS=3
# Interval cek posisi (dalam detik)
CHECK_INTERVAL_SECONDS=60
# Minimum fee APR untuk masuk pool (%)
MIN_FEE_APR=20
# Maksimum loss sebelum keluar dari posisi (%)
MAX_LOSS_PERCENT=5

# ===== JUPITER =====
JUPITER_API_URL=https://quote-api.jup.ag/v6

# ===== METEORA =====
METEORA_API_URL=https://dlmm-api.meteora.ag

# ===== TELEGRAM ALERTS (opsional) =====
# Cara setup: buat bot via @BotFather, lalu /getid di @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== DASHBOARD =====
DASHBOARD_PORT=3000
