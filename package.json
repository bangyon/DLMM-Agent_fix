{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "description": "AI-powered DLMM LP Agent for Meteora",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "nodemon --exec ts-node src/index.ts",
    "backtest": "ts-node src/index.ts --backtest 7",
    "backtest:14": "ts-node src/index.ts --backtest 14",
    "report": "ts-node src/index.ts --report"
  },
  "dependencies": {
    "@meteora-ag/dlmm": "^1.3.0",
    "@solana/web3.js": "^1.91.0",
    "@jup-ag/api": "^6.0.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2",
    "openai": "^4.52.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "@types/node": "^20.14.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "@types/ws": "^8.5.10"
  }
}